#!/usr/bin/env python3
import gi
import sys
import os
import subprocess
import time
import argparse
import shutil
import json
from datetime import datetime

gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib, Pango

# --- CONFIGURATION ---
CONFIG_DIR = os.path.expanduser("~/.config/guhshot")
CONFIG_FILE = os.path.join(CONFIG_DIR, "config.json")
DEFAULT_SAVE_DIR = os.path.expanduser("~/Pictures/Screenshots")

# This sets the Wayland App ID and the primary display name
GLib.set_prgname('guhShot')
GLib.set_application_name('guhShot')

DEFAULT_CONFIG = {
    "mode": "full",
    "delay": 0,
    "save_to_file": True,
    "copy_clipboard": True,
    "open_swappy": False,
    "save_dir": DEFAULT_SAVE_DIR
}

WINDOW_BASE_COLOR = "rgba(194, 174, 157, 0.75)" 
WIDGET_BG = "rgba(255, 255, 255, 0.12)"
SHUTTER_COLOR = "rgba(215, 206, 199, 0.7)"
TEXT_GRAY = "#4d4d4d"

def load_config():
    if not os.path.exists(CONFIG_FILE):
        return DEFAULT_CONFIG
    try:
        with open(CONFIG_FILE, 'r') as f:
            return {**DEFAULT_CONFIG, **json.load(f)}
    except:
        return DEFAULT_CONFIG

def save_config(config):
    if not os.path.exists(CONFIG_DIR):
        os.makedirs(CONFIG_DIR)
    with open(CONFIG_FILE, 'w') as f:
        json.dump(config, f, indent=4)

class GuhShot(Gtk.Window):
    def __init__(self):
        super().__init__(title="guhShot")
        
        self.config = load_config()
        self.save_dir = self.config["save_dir"]

        self.set_border_width(0)
        self.set_resizable(False)
        self.set_keep_above(True)
        self.set_position(Gtk.WindowPosition.CENTER)
        
        if not os.path.exists(self.save_dir):
            os.makedirs(self.save_dir)

        self.set_visual(self.get_screen().get_rgba_visual())
        self.apply_styling()

        self.main_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        self.main_box.set_name("main-container")
        self.add(self.main_box)

        # --- CAPTURE SECTION ---
        self.main_box.pack_start(self.create_header("CAPTURE", top_margin=0), False, False, 0)
        cap_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        cap_box.set_name("section")
        
        self.full_radio = Gtk.RadioButton.new(None)
        self.full_radio.connect("toggled", self.sync_settings)
        cap_box.pack_start(self.create_row("Fullscreen", self.full_radio), False, False, 0)
        
        self.region_radio = Gtk.RadioButton.new_from_widget(self.full_radio)
        cap_box.pack_start(self.create_row("Region", self.region_radio), False, False, 0)

        if self.config["mode"] == "region":
            self.region_radio.set_active(True)
        else:
            self.full_radio.set_active(True)

        self.delay_spin = Gtk.SpinButton.new_with_range(0, 10, 1)
        self.delay_spin.set_value(self.config["delay"])
        self.delay_spin.connect("value-changed", self.sync_settings)
        self.delay_spin.set_size_request(60, -1)
        self.delay_spin.set_name("translucent-widget")
        cap_box.pack_start(self.create_row("Delay", self.delay_spin), False, False, 0)
        
        self.main_box.pack_start(cap_box, False, False, 0)

        # --- OUTPUT SECTION ---
        self.main_box.pack_start(self.create_header("OUTPUT", top_margin=12), False, False, 0)
        out_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=10)
        out_box.set_name("section")

        self.switch_swappy = Gtk.Switch(active=self.config["open_swappy"])
        self.switch_clip = Gtk.Switch(active=self.config["copy_clipboard"])
        self.switch_save = Gtk.Switch(active=self.config["save_to_file"])

        self.switch_swappy.connect("notify::active", self.sync_settings)
        self.switch_clip.connect("notify::active", self.sync_settings)
        self.switch_save.connect("notify::active", self.sync_settings)

        out_box.pack_start(self.create_row("Open in Swappy", self.switch_swappy), False, False, 0)
        out_box.pack_start(self.create_row("Copy to Clipboard", self.switch_clip), False, False, 0)
        out_box.pack_start(self.create_row("Save to File", self.switch_save), False, False, 0)

        # Location Row
        loc_inner_vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        loc_main_label = Gtk.Label(label="Location")
        loc_main_label.set_xalign(0)
        self.loc_path_label = Gtk.Label()
        self.loc_path_label.set_markup(f"<span size='small' alpha='55%'>{self.save_dir}</span>")
        self.loc_path_label.set_ellipsize(Pango.EllipsizeMode.END)
        self.loc_path_label.set_xalign(0)
        loc_inner_vbox.pack_start(loc_main_label, False, False, 0)
        loc_inner_vbox.pack_start(self.loc_path_label, False, False, 0)

        self.folder_btn = Gtk.Button()
        folder_icon_label = Gtk.Label(label="")
        folder_icon_label.set_name("folder-icon-label")
        self.folder_btn.add(folder_icon_label)
        self.folder_btn.set_name("folder-icon-btn")
        self.folder_btn.set_valign(Gtk.Align.CENTER)
        self.folder_btn.set_margin_end(10)
        self.folder_btn.connect("clicked", self.on_folder_clicked)
        
        out_box.pack_start(self.create_row(loc_inner_vbox, self.folder_btn), False, False, 0)
        self.main_box.pack_start(out_box, False, False, 0)

        # --- SHUTTER BUTTON ---
        shutter_btn = Gtk.Button()
        shutter_btn.set_name("shutter")
        shutter_btn.set_size_request(85, 85)
        shutter_btn.connect("clicked", self.on_shutter_clicked)
        
        shutter_center = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        shutter_center.set_center_widget(shutter_btn)
        self.main_box.pack_start(shutter_center, False, False, 15)

        self.connect("destroy", Gtk.main_quit)
        self.show_all()

    def sync_settings(self, *args):
        self.config = {
            "mode": "full" if self.full_radio.get_active() else "region",
            "delay": self.delay_spin.get_value_as_int(),
            "save_to_file": self.switch_save.get_active(),
            "copy_clipboard": self.switch_clip.get_active(),
            "open_swappy": self.switch_swappy.get_active(),
            "save_dir": self.save_dir
        }
        save_config(self.config)

    def create_header(self, text, top_margin=0):
        lbl = Gtk.Label()
        lbl.set_markup(f"<span weight='bold' size='14000' alpha='85%'>{text}</span>")
        lbl.set_xalign(0)
        lbl.set_margin_start(5)
        lbl.set_margin_top(top_margin)
        lbl.set_margin_bottom(2) 
        return lbl

    def create_row(self, label_content, widget):
        hbox = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
        if isinstance(label_content, str):
            lbl = Gtk.Label(label=label_content)
            lbl.set_xalign(0)
            hbox.pack_start(lbl, True, True, 0)
        else:
            hbox.pack_start(label_content, True, True, 0)
        hbox.pack_end(widget, False, False, 0)
        return hbox

    def apply_styling(self):
        css_provider = Gtk.CssProvider()
        css = f"""
            * {{ font-size: 13pt; color: {TEXT_GRAY}; outline: none; }}
            window {{ background-color: transparent; }}
            #main-container {{ background-color: {WINDOW_BASE_COLOR}; border-radius: 0; padding: 24px; }}
            #section {{ background-color: {WIDGET_BG}; border-radius: 18px; padding: 12px 15px; }}
            #translucent-widget {{ background-color: rgba(255, 255, 255, 0.2); border: 1px solid rgba(0, 0, 0, 0.1); border-radius: 10px; }}
            #folder-icon-btn {{ background: transparent; background-image: none; border: none; box-shadow: none; padding: 0; margin: 0; }}
            #folder-icon-label {{ font-size: 23pt; opacity: 0.6; }}
            #folder-icon-btn:hover #folder-icon-label {{ opacity: 0.95; }}
            #shutter {{ background-color: {SHUTTER_COLOR}; background-image: none; border-radius: 1000px; border: 6px solid rgba(51, 51, 51, 0.8); box-shadow: none; }}
            #shutter:hover {{ border-color: #000000; background-color: rgba(215, 206, 199, 0.9); }}
            switch {{ background-color: rgba(0, 0, 0, 0.1); border-radius: 20px; }}
            switch slider {{ background-color: white; border-radius: 100%; }}
            switch:checked {{ background-color: rgba(255, 255, 255, 0.4); }}
        """
        css_provider.load_from_data(css.encode())
        Gtk.StyleContext.add_provider_for_screen(Gdk.Screen.get_default(), css_provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

    def on_folder_clicked(self, widget):
        dialog = Gtk.FileChooserDialog(title="Select Save Folder", parent=self, action=Gtk.FileChooserAction.SELECT_FOLDER)
        dialog.add_buttons(Gtk.STOCK_CANCEL, Gtk.ResponseType.CANCEL, "Select", Gtk.ResponseType.OK)
        response = dialog.run()
        if response == Gtk.ResponseType.OK:
            self.save_dir = dialog.get_filename()
            self.loc_path_label.set_markup(f"<span size='small' alpha='55%'>{self.save_dir}</span>")
            self.sync_settings()
        dialog.destroy()

    def on_shutter_clicked(self, widget):
        self.sync_settings()
        self.hide()
        while Gtk.events_pending():
            Gtk.main_iteration()
            
        take_screenshot(
            mode=self.config["mode"], 
            delay=self.config["delay"], 
            save=self.config["save_to_file"], 
            clipboard=self.config["copy_clipboard"], 
            swappy=self.config["open_swappy"], 
            directory=self.config["save_dir"]
        )
        Gtk.main_quit()

def take_screenshot(mode="full", delay=0, save=True, clipboard=True, swappy=False, directory=DEFAULT_SAVE_DIR):
    if delay > 0:
        time.sleep(delay)
    timestamp = datetime.now().strftime("%Y-%m-%d_%H-%M-%S.png")
    filename = f"guhShot_{timestamp}"
    filepath = os.path.join(directory, filename)
    tmp_path = f"/tmp/{filename}"
    
    cmd = ["grim"]
    if mode == "region":
        try:
            slurp = subprocess.check_output(["slurp"]).decode().strip()
            cmd += ["-g", slurp]
        except subprocess.CalledProcessError:
            return 
    cmd.append(tmp_path)
    subprocess.run(cmd)
    
    if not os.path.exists(tmp_path):
        return
    if swappy:
        subprocess.run(["swappy", "-f", tmp_path, "-o", tmp_path])
    
    notifs = []
    if clipboard:
        subprocess.run(f"wl-copy -t image/png < {tmp_path}", shell=True)
        notifs.append("Copied to Clipboard!")
    if save:
        if not os.path.exists(directory):
            os.makedirs(directory)
        shutil.move(tmp_path, filepath)
        notifs.append(f"Saved to {filepath}")
    else:
        if os.path.exists(tmp_path):
            os.remove(tmp_path)
    if notifs:
        msg = "\n".join(notifs)
        subprocess.run(["notify-send", "guhShot", msg, "-a", "guhShot"])

if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("--full", action="store_true")
    parser.add_argument("--region", action="store_true")
    args = parser.parse_args()
    
    if args.full or args.region:
        conf = load_config()
        mode = "full" if args.full else "region"
        take_screenshot(
            mode=mode, 
            delay=conf["delay"], 
            save=conf["save_to_file"], 
            clipboard=conf["copy_clipboard"], 
            swappy=conf["open_swappy"], 
            directory=conf["save_dir"]
        )
    else:
        win = GuhShot()
        Gtk.main()
